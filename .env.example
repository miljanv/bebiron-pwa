# Next.js (preferred)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# React Native Expo names are also supported as fallback:
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.2

# Web Push (generate with: npm run generate:vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Server-only — required for cron push delivery
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Vercel: add all vars above in Project Settings → Environment Variables
# for Production, Preview, and Development environments.
